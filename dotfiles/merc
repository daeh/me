#!/bin/zsh
# ~/.merc --- Rocky 8.10+ (ORCD) runtime helpers. Sourced from ~/.zshrc.
#
# PATH assembly happens in .zshenv (so sbatch non-login zsh sees it too).
# This file holds shell-level helpers, terminal-color hash, and exports that
# depend on an interactive session.

# --- PATH helpers (idempotent) ---

prepend_to_path_if_not_exists() {
    local -a to_add=()
    local dir
    for dir in "$@"; do
        dir=${dir%/}
        if [[ -d "$dir" ]]; then
            (( ${path[(I)$dir]} == 0 )) && to_add+=("$dir")
        else
            printf 'prepend_to_path_if_not_exists: warning: %s not a directory\n' "$dir" >&2
        fi
    done
    (( ${#to_add} )) && path=("${to_add[@]}" "${path[@]}")
}

append_to_path_if_not_exists() {
    local -a to_add=()
    local dir
    for dir in "$@"; do
        dir=${dir%/}
        if [[ -d "$dir" ]]; then
            (( ${path[(I)$dir]} == 0 )) && to_add+=("$dir")
        else
            printf 'append_to_path_if_not_exists: warning: %s not a directory\n' "$dir" >&2
        fi
    done
    (( ${#to_add} )) && path=("${path[@]}" "${to_add[@]}")
}

# --- Terminal color hash: stable color per host for tmux status bar. ---

{
    local _host_hash
    _host_hash=$(printf '%s' "${HOST:-$HOSTNAME}" | shasum 2>/dev/null | cut -c1-6)
    [[ -n "$_host_hash" ]] && export TMUX_COLOR="#${_host_hash}"
}

# --- Exports that callers (tmux, uv, etc.) read. ---

export DEFAULT_TMUX_SHELL="$ME_PREFIX/bin/zsh"

# Re-apply PATH once fnm's env has mutated it, in case fnm's install pushed
# the default node ahead of $ME_PREFIX/bin (it shouldn't, but belt-and-braces).
typeset -U path
